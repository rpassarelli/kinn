---
import "../styles/global.css";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1440" />
  <title>kinn3 demo · mockup playground</title>
</head>
<body>
  <header class="mock-header">
    <h1>kinn3 demo · <span class="mock-h-sub">mockup playground</span></h1>
    <div class="mock-h-meta">
      type <code>M.help()</code> in console · panel ids <code>p1</code>..<code>p5</code>
    </div>
  </header>

  <main>
    <section class="mock-panel" id="mock-p1" data-pid="p1">
      <span class="mock-tag">01</span>
      <span class="mock-panel-label">P1</span>
    </section>
    <section class="mock-panel" id="mock-p2" data-pid="p2">
      <span class="mock-tag">02</span>
      <span class="mock-panel-label">P2</span>
    </section>
    <section class="mock-panel" id="mock-p3" data-pid="p3">
      <span class="mock-tag">03</span>
      <span class="mock-panel-label">P3</span>
    </section>
    <section class="mock-panel" id="mock-p4" data-pid="p4">
      <span class="mock-tag">04</span>
      <span class="mock-panel-label">P4</span>
    </section>
    <section class="mock-panel" id="mock-p5" data-pid="p5">
      <span class="mock-tag">05</span>
      <span class="mock-panel-label">P5</span>
    </section>

    <svg id="mock-arrows">
      <defs>
        <marker id="mock-arrowhead" viewBox="0 0 10 10" refX="9" refY="5"
                markerWidth="6" markerHeight="6" orient="auto">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
        </marker>
      </defs>
    </svg>

    <div id="mock-caption" class="mock-caption">
      <span id="mock-caption-label" class="mock-caption-label"></span>
      <span id="mock-caption-text" class="mock-caption-text"></span>
    </div>
  </main>

  <aside class="mock-controls" id="mock-controls">
    <div class="ctrl-section">
      <div class="ctrl-label">target</div>
      <div class="chip-row" data-role="target">
        <button class="chip chip-p1" data-pid="p1">P1</button>
        <button class="chip chip-p2" data-pid="p2">P2</button>
        <button class="chip chip-p3" data-pid="p3">P3</button>
        <button class="chip chip-p4" data-pid="p4">P4</button>
        <button class="chip chip-p5" data-pid="p5">P5</button>
      </div>
    </div>

    <div class="ctrl-section">
      <div class="ctrl-label">effects</div>
      <div class="btn-row">
        <button class="ctrl-btn" data-cmd="highlight">Highlight</button>
        <button class="ctrl-btn" data-cmd="flash">Flash</button>
        <button class="ctrl-btn" data-cmd="shake">Shake</button>
        <button class="ctrl-btn" data-cmd="spotlight">Spotlight</button>
      </div>
      <div class="btn-row">
        <button class="ctrl-btn" data-cmd="dim">Dim</button>
        <button class="ctrl-btn" data-cmd="undim-all">Undim all</button>
      </div>
    </div>

    <div class="ctrl-section">
      <div class="ctrl-label">connect</div>
      <div class="from-to">
        <span>from</span>
        <div class="chip-row mini" data-role="from">
          <button class="chip chip-p1" data-pid="p1">1</button>
          <button class="chip chip-p2" data-pid="p2">2</button>
          <button class="chip chip-p3" data-pid="p3">3</button>
          <button class="chip chip-p4" data-pid="p4">4</button>
          <button class="chip chip-p5" data-pid="p5">5</button>
        </div>
        <span>→ to</span>
        <div class="chip-row mini" data-role="to">
          <button class="chip chip-p1" data-pid="p1">1</button>
          <button class="chip chip-p2" data-pid="p2">2</button>
          <button class="chip chip-p3" data-pid="p3">3</button>
          <button class="chip chip-p4" data-pid="p4">4</button>
          <button class="chip chip-p5" data-pid="p5">5</button>
        </div>
      </div>
      <div class="btn-row">
        <button class="ctrl-btn" data-cmd="arrow">Arrow</button>
        <button class="ctrl-btn" data-cmd="particles">Particles</button>
      </div>
    </div>

    <div class="ctrl-section">
      <div class="ctrl-label">caption</div>
      <div class="caption-row">
        <input type="text" id="cap-label" class="ctrl-input" placeholder="STEP LABEL (optional)" />
        <input type="text" id="cap-text" class="ctrl-input" placeholder="caption text…" />
      </div>
      <div class="btn-row">
        <button class="ctrl-btn primary" data-cmd="caption-show">Show caption</button>
        <button class="ctrl-btn" data-cmd="caption-clear">Hide</button>
      </div>
    </div>

    <div class="ctrl-section">
      <div class="ctrl-label">reset</div>
      <div class="btn-row">
        <button class="ctrl-btn" data-cmd="grid-reset">Grid reset</button>
        <button class="ctrl-btn warn" data-cmd="clear-all">Clear all</button>
      </div>
    </div>
  </aside>

  <script>
    import { startMockup, bindMockupControls } from "../scripts/mockup.ts";
    startMockup();
    bindMockupControls();
  </script>
</body>

<style is:global>
  .mock-header {
    padding: 12px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--panel);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .mock-header h1 { font-size: 18px; font-weight: 700; }
  .mock-h-sub { color: var(--text-dim); font-weight: 400; margin-left: 8px; }
  .mock-h-meta { font-family: ui-monospace, monospace; font-size: 12px; color: var(--text-dim); }
  .mock-h-meta code {
    background: var(--panel-2); padding: 2px 6px; border-radius: 4px;
    color: var(--gold); font-size: 11px;
  }

  main {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    grid-template-rows: 1fr 1fr;
    grid-template-areas:
      "p1 p2 p3"
      "p5 p5 p4";
    gap: 10px;
    padding: 10px;
    background: var(--bg);
    overflow: hidden;
    position: relative;
  }

  .mock-panel {
    background: var(--panel);
    border: 2px solid var(--border);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    will-change: transform, opacity, box-shadow, background-color;
  }
  #mock-p1 { grid-area: p1; }
  #mock-p2 { grid-area: p2; }
  #mock-p3 { grid-area: p3; }
  #mock-p4 { grid-area: p4; }
  #mock-p5 { grid-area: p5; }

  .mock-tag {
    position: absolute;
    top: 14px; right: 18px;
    font-family: ui-monospace, monospace;
    font-size: 56px;
    font-weight: 800;
    color: var(--text-muted);
    opacity: 0.18;
    line-height: 1;
    pointer-events: none;
  }
  .mock-panel-label {
    font-size: 64px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
    font-family: -apple-system, "Inter", sans-serif;
  }

  /* Distinct accent per panel so spotlight/flash effects are visible */
  #mock-p1 { background: linear-gradient(135deg, #14181f, #1c2230); }
  #mock-p1 .mock-panel-label { color: var(--user); }
  #mock-p2 { background: linear-gradient(135deg, #14181f, #1c2230); }
  #mock-p2 .mock-panel-label { color: var(--signal); }
  #mock-p3 { background: linear-gradient(135deg, #14181f, #1c2230); }
  #mock-p3 .mock-panel-label { color: var(--high); }
  #mock-p4 { background: linear-gradient(135deg, #14181f, #1c2230); }
  #mock-p4 .mock-panel-label { color: var(--gold); }
  #mock-p5 { background: linear-gradient(135deg, #14181f, #1c2230); }
  #mock-p5 .mock-panel-label { color: var(--goal); }

  /* SVG arrows layer (covers full main) */
  #mock-arrows {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 50;
  }

  /* Caption overlay */
  .mock-caption {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    width: min(820px, 84vw);
    text-align: center;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    color: var(--text);
    background: linear-gradient(180deg, rgba(10,13,18,0.0), rgba(10,13,18,0.85) 50%);
    padding: 22px 28px 14px;
    border-radius: 16px;
  }
  .mock-caption-label {
    display: block;
    font-family: ui-monospace, monospace;
    font-size: 13px;
    letter-spacing: 0.26em;
    color: var(--gold);
    margin-bottom: 12px;
    text-transform: uppercase;
    font-weight: 800;
  }
  .mock-caption-text {
    display: block;
    font-size: 22px;
    line-height: 1.45;
    font-weight: 500;
  }
  .mock-caption-text b { color: var(--gold); font-weight: 700; }

  /* ── Floating control panel ─────────────────────── */
  .mock-controls {
    position: fixed;
    right: 16px;
    bottom: 16px;
    width: 320px;
    background: rgba(20,24,33,0.96);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    z-index: 300;
    font-family: -apple-system, "Inter", sans-serif;
    color: var(--text);
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 36px rgba(0,0,0,0.55);
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: calc(100vh - 32px);
    overflow-y: auto;
  }
  .ctrl-section { display: flex; flex-direction: column; gap: 6px; }
  .ctrl-label {
    font-family: ui-monospace, monospace;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 10px;
    color: var(--gold);
    font-weight: 800;
  }

  .chip-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .chip-row.mini .chip { padding: 4px 9px; font-size: 11px; min-width: 26px; }
  .chip {
    flex: 1 0 auto;
    background: var(--panel-2);
    color: var(--text-dim);
    border: 2px solid transparent;
    border-radius: 7px;
    padding: 7px 10px;
    cursor: pointer;
    font-family: ui-monospace, monospace;
    font-weight: 700;
    font-size: 13px;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .chip:hover { background: var(--border); }
  .chip.chip-p1.active { border-color: var(--user);   color: var(--user); }
  .chip.chip-p2.active { border-color: var(--signal); color: var(--signal); }
  .chip.chip-p3.active { border-color: var(--high);   color: var(--high); }
  .chip.chip-p4.active { border-color: var(--gold);   color: var(--gold); }
  .chip.chip-p5.active { border-color: var(--goal);   color: var(--goal); }

  .btn-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .ctrl-btn {
    flex: 1 1 auto;
    background: var(--panel-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 8px 10px;
    cursor: pointer;
    font-family: -apple-system, "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .ctrl-btn:hover { background: var(--border); }
  .ctrl-btn:active { transform: scale(0.97); }
  .ctrl-btn.primary { background: var(--high); color: #06121f; border-color: var(--high); font-weight: 700; }
  .ctrl-btn.primary:hover { background: #4dcb62; }
  .ctrl-btn.warn { background: rgba(255,90,90,0.12); border-color: rgba(255,90,90,0.4); color: #ff9090; }
  .ctrl-btn.warn:hover { background: rgba(255,90,90,0.25); }

  .from-to {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: ui-monospace, monospace;
    font-size: 11px;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .caption-row { display: flex; flex-direction: column; gap: 6px; }
  .ctrl-input {
    background: var(--panel-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 7px 10px;
    font-family: -apple-system, "Inter", sans-serif;
    font-size: 12px;
    width: 100%;
  }
  .ctrl-input::placeholder { color: var(--text-muted); }
  .ctrl-input:focus {
    outline: none;
    border-color: var(--gold);
  }
</style>
</html>
