---
import { PANEL_ICONS } from "../scripts/icons";
---
<section class="panel" id="panel-05">
  <div class="panel-tag">05</div>
  <div class="panel-title">
    <span class="panel-icon" set:html={PANEL_ICONS.question} />
    Questioner · build the next probe
  </div>
  <div class="quest-cues" id="quest-cues">
    <div class="cue">
      <div class="cue-label">algedonic · is it hurting?</div>
      <div class="cue-value"><span id="alg-pill" class="cue-pill pill-empty">empty</span></div>
    </div>
    <div class="cue">
      <div class="cue-label">goal · target block</div>
      <div class="cue-value">
        <span id="goal-icon" class="cue-icon"></span>
        <span id="goal-name">none</span>
      </div>
    </div>
  </div>
  <div class="next-q-box" id="next-q-box">
    <div class="next-q-text" id="next-q-text">— waiting for objective —</div>
  </div>
</section>

<style is:global>
  .quest-cues {
    display: flex;
    gap: 18px;
    margin: 10px 0 22px;
    opacity: 0;
  }
  .cue {
    flex: 1;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cue-label {
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    font-family: ui-monospace, monospace;
    font-weight: 700;
  }
  .cue-value {
    font-size: 30px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .cue-icon {
    width: 36px;
    height: 36px;
    color: var(--goal);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .cue-icon svg { width: 100%; height: 100%; display: block; }
  .cue-pill {
    font-size: 20px;
    padding: 6px 16px;
    border-radius: 12px;
    font-family: ui-monospace, monospace;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .next-q-box {
    flex: 1;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, rgba(63, 185, 80, 0.10), rgba(63, 185, 80, 0.04));
    border: 1px solid rgba(63, 185, 80, 0.4);
    border-radius: 14px;
    padding: 28px 32px;
    opacity: 0;
  }
  .next-q-text {
    font-size: 34px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
  }
</style>
