---
import { PANEL_ICONS } from "../scripts/icons";
---
<section class="panel" id="panel-04">
  <div class="panel-tag">04</div>
  <div class="panel-title">
    <span class="panel-icon" set:html={PANEL_ICONS.cog} />
    Router · process · update · pick goal
  </div>
  <div class="router">
    <div class="router-col in-col">
      <div class="router-col-label">in: signals</div>
      <div id="router-in"></div>
    </div>
    <div class="router-core" id="router-core" set:html={PANEL_ICONS.cog} />
    <div class="router-col out-col">
      <div class="router-col-label">out: mutations · objective</div>
      <div id="router-out"></div>
    </div>
  </div>
</section>

<style is:global>
  .router {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 14px;
    padding: 10px 4px;
  }
  .router-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 0;
    overflow: hidden;
  }
  .router-col.in-col { align-items: flex-end; text-align: right; }
  .router-col.out-col { align-items: flex-start; text-align: left; }
  .router-col-label {
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    font-family: ui-monospace, monospace;
    margin-bottom: 8px;
  }
  .router-core {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 211, 61, 0.25), rgba(255, 211, 61, 0.05));
    border: 3px solid rgba(255, 211, 61, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    position: relative;
  }
  .router-core svg { width: 60px; height: 60px; display: block; }
  .router-chip {
    font-size: 20px;
    padding: 10px 14px;
    border-radius: 10px;
    font-family: ui-monospace, monospace;
    font-weight: 600;
    background: var(--panel-2);
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    white-space: nowrap;
    max-width: 100%;
  }
  .router-chip svg { width: 22px; height: 22px; flex-shrink: 0; }
  .router-chip.signal { border-color: var(--signal); color: var(--signal); }
  .router-chip.mutation {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(255, 211, 61, 0.08);
  }
  .router-chip.mutation .to {
    font-size: 16px;
    padding: 3px 10px;
    border-radius: 8px;
    background: rgba(63, 185, 80, 0.3);
    color: var(--high);
    margin-left: 6px;
    font-family: ui-monospace, monospace;
  }
  .router-chip.objective {
    border-color: var(--goal);
    color: var(--goal);
    background: rgba(210, 168, 255, 0.08);
    font-weight: 700;
  }
</style>
