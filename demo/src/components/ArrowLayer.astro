<style is:global>
  #arrow-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 50;
  }
  /* GSAP drives stroke, opacity, dasharray, dashoffset directly. */
  .arrow-path {
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    opacity: 0;
  }
</style>
